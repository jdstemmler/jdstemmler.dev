---
// The site's signature element: a two-channel instrument readout.
// Symptom (muted, observed) over cause (signal, the needle deflection).
// The cause row's reveal one beat after load is the entire site's motion budget.
interface Props {
  symptom: string;
  cause: string;
}

const { symptom, cause } = Astro.props;
---

<div class="readout" role="group" aria-label="Diagnosis">
  <div class="row symptom">
    <div class="cell-label"><span class="label">Symptom</span></div>
    <div class="cell-value"><p class="sym-text">{symptom}</p></div>
  </div>
  <div class="row cause">
    <div class="cell-label"><span class="label">Cause</span></div>
    <div class="cell-value"><p class="cause-text">{cause}</p></div>
  </div>
</div>

<style>
  /* Unboxed instrument readout: mono labels and the signal gutter tick carry
     the structure — no callout border (cold design read: the box diluted it). */
  .readout {
    margin: 2.4rem 0 2.8rem;
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 1.15rem 1.5rem;
  }
  .row {
    display: contents;
  }
  .cell-label {
    padding: 0.2rem 0 0 1rem;
    display: flex;
    align-items: flex-start;
    position: relative;
  }
  .cell-value {
    padding: 0;
  }
  .cell-value p {
    margin: 0;
  }
  .sym-text {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.4;
    color: var(--muted);
  }
  .cause-text {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.2rem;
    line-height: 1.3;
    letter-spacing: -0.005em;
    color: var(--signal);
  }
  /* the needle: a signal tick in the cause label gutter */
  .row.cause .cell-label::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.1rem;
    bottom: 0.1rem;
    width: 3px;
    background: var(--signal);
    transform: scaleY(1);
    transform-origin: top;
  }

  @media (prefers-reduced-motion: no-preference) {
    .row.cause .cause-text {
      opacity: 0;
      transform: translateY(4px);
      animation: reveal 420ms cubic-bezier(0.2, 0.7, 0.2, 1) 180ms forwards;
    }
    .row.cause .cell-label::before {
      transform: scaleY(0);
      animation: tick 420ms cubic-bezier(0.2, 0.7, 0.2, 1) 180ms forwards;
    }
    @keyframes reveal {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    @keyframes tick {
      to {
        transform: scaleY(1);
      }
    }
  }

  @media (max-width: 620px) {
    .readout {
      grid-template-columns: 1fr;
      gap: 0.45rem;
    }
    .cell-label {
      padding: 0 0 0 1rem;
    }
    .row.cause .cell-label {
      margin-top: 1.1rem;
    }
    .row.cause .cell-label::before {
      top: 0;
      bottom: 0;
    }
  }
</style>
