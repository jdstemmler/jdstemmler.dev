---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const recent = posts.slice(0, 5);
---

<Base
  title="jdstemmler.dev"
  description="Homelab, self-hosting, and Claude Code — write-ups of specific fixes, with the wrong hypothesis named first."
>
  <p class="label">Field notes</p>
  <h1 class="page-title">Homelab, self-hosting, and Claude Code</h1>
  <div class="prose">
    <p>
      I'm Jayson Stemmler, a data scientist who runs a homelab and self-hosts more than is
      strictly sensible. This site collects the things I've learned that weren't obvious —
      problems that took real digging to diagnose, written down clearly enough that the next
      person doesn't lose an evening to them.
    </p>
    <p>
      Each debugging post opens with the wrong hypothesis first, because that's usually what
      you currently believe. Every command shown was actually run, and every number is real.
    </p>
  </div>

  <h2 class="label" style="margin: 2.6rem 0 0.4rem;">Recent posts</h2>
  <ul class="post-list">
    {
      recent.map((post) => (
        <li>
          <p class="entry-meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toISOString().slice(0, 10)}
            </time>
            {' · '}
            {post.data.tags.join(' · ')}
          </p>
          <h3 class="entry-title">
            <a href={`/posts/${post.id}/`}>{post.data.title}</a>
          </h3>
          {post.data.symptom && post.data.cause && (
            <dl class="mini-readout">
              <dt class="label">Symptom</dt>
              <dd class="mini-sym">{post.data.symptom}</dd>
              <dt class="label">Cause</dt>
              <dd class="mini-cause">{post.data.cause}</dd>
            </dl>
          )}
        </li>
      ))
    }
  </ul>
</Base>

<style>
  .mini-readout {
    margin: 0.8rem 0 0;
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.35rem 1.1rem;
  }
  .mini-readout dt {
    padding-top: 0.2em;
  }
  .mini-readout dd {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.5;
  }
  .mini-sym {
    color: var(--muted);
  }
  .mini-cause {
    color: var(--signal);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: -0.005em;
  }
  @media (max-width: 620px) {
    .mini-readout {
      grid-template-columns: 1fr;
      gap: 0.1rem 0;
    }
    .mini-readout dt {
      padding-top: 0.55rem;
    }
    .mini-readout dt:first-child {
      padding-top: 0;
    }
  }
</style>
